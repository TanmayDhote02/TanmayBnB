<% layout("/layouts/boilerplate") %> <!-- is layout use karne se html ka set custome boilerplate milta h -->
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/delete-confirm.css">
    <div class="container pb-4">
        <div class="main-profiles mt-2" data-aos="zoom-in" data-aos-duration="1000">
            <div class="main-profile-detail">
                <div class="profile-img listing-card" style="transition: all 0.4s ease;">
                    <% if(!currUser.image.url) {%>
                        <img src="/Icon/navbar-icon-user.png">
                        <% } else{%>
                            <img src="<%= currUser.image.url %>">
                            <% } %>
                                <div id="change-image">
                                    <a href="/change-image/<%= currUser._id %>">
                                        <i class="fa-solid fa-camera"></i>
                                    </a>
                                </div>
                </div>
                <div class="profile-user">
                    <h3><span>Name : </span>
                        <%= currUser.fName.split("")[0].toUpperCase() %>
                            <%= currUser.fName.slice(1).toLowerCase() %>&nbsp;<%= currUser.lName %>
                    </h3>
                    <h3><span>Username : </span>@<%= currUser.username %>
                    </h3>
                    <h4><span>Email : </span>
                        <%= currUser.email.split("").slice(0,2).join("") %>xxxxx@<%= currUser.email.split("@")[1] %>
                    </h4>
                </div>
                <div class="manage">
                    <form action="/update-form/<%= currUser._id %>" class="needs-validation">
                        <button class="update btn">Update Ac</button>
                    </form>
                    <form method="post" action="/delete/<%= currUser._id %>?_method=DELETE" class="needs-validation">
                        <button type="reset" class="list-btn btn list-delete" id="delete-confirm">Delete Ac</button>
                        <div class="fnx-fixed-dis">
                            <div class="delete-fnx" style="display: none;">
                                <p><b>Are you sure</b></p>
                                <p>you want to delete your account?</p>
                                <div class="conf cancle-confirm">Cancel</div>
                                <button class="conf delete-confirm">Confirm</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="manage manage-hide">
                <form action="/update-form/<%= currUser._id %>" class="needs-validation">
                    <button class="update btn">Update Ac</button>
                </form>
                <form method="post" action="/delete/<%= currUser._id %>?_method=DELETE" class="needs-validation">
                    <button type="reset" class="list-btn btn list-delete" id="delete-confirm">Delete Ac</button>
                    <div class="fnx-fixed-dis">
                        <div class="delete-fnx" style="display: none;">
                            <p><b>Are you sure</b></p>
                            <p>you want to delete your account?</p>
                            <div class="conf cancle-confirm">Cancel</div>
                            <button class="conf delete-confirm">Confirm</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="choose-list" data-aos="fade-up" data-aos-duration="800">
                <div>
                    <label for="listBtn"><b>Listings</b></label>
                    <input type="radio" name="listing" id="listBtn" checked>
                </div>
                <div>
                    <label for="reviBtn"><b>Reviews</b></label>
                    <input type="radio" name="listing" id="reviBtn">
                </div>
                <div>
                    <label for="bookBtn"><b>Bookings</b></label>
                    <input type="radio" name="listing" id="bookBtn">
                </div>
            </div>
        </div>


        <!-- reviews show -->
        <div id="review-box-start" style="display: none;">
            <hr>
            <div class="listing-count">
                <h3 class="index-res">@<%= currUser.username %> Created&nbsp;<b class="text-success fs-4">
                            <%= allReview.length %>
                        </b>&nbsp;Reviews</h3>
                <form method="post" action="/profile/all-reviews-delete/<%= currUser._id %>?_method=DELETE"
                    class="needs-validation">
                    <button type="reset" class="deleteAll delete-list" id="delete-confirm">Delete All</button>
                    <div class="fnx-fixed-dis">
                        <div class="delete-fnx" style="display: none;">
                            <p>Are you sure you want to delete the entire reviews?</p>
                            <div class="conf cancle-confirm">Cancel</div>
                            <button class="conf delete-confirm">Confirm</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="row row-cols-xxl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-1 profile-box">
                <% for (const review of allReview) { %>
                    <div class="listing-link">
                        <div class="card col listing-card index-res">
                            <div class="index-res-img">
                                <div class="card-body mt-1 ms-2" id="review-body">
                                    <span><b>Date :</b>
                                        <%= review.createAt.toString().split(" ").slice(1,4).join(" -") %>
                                    </span><br>
                                    <span><b>Time :</b>
                                        <%= review.createAt.toString().split(" ")[4] %></span><br>
                                    <span><b>Comment :</b> <%= review.comment %></span><br>
                                    <span class=" ratingBox"><b>Rating : &nbsp;</b>
                                            <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                    </span>
                                </div>
                                <div class="lists-btn mt-1">
                                    <button class="list-btn list-show"><a
                                            href="/listings/<%= review.listing %>">Show</a></button>
                                    <form method="post"
                                        action="/profile/review/<%= review.listing %>/<%= review._id %>?_method=DELETE"
                                        class="needs-validation">
                                        <button type="reset" class="list-btn list-delete"
                                            id="delete-confirm">Delete</button>
                                        <div class="fnx-fixed-dis">
                                            <div class="delete-fnx" style="display: none;">
                                                <p>I want to delete this review.</p>
                                                <p>"<%= review.comment %>"</p>
                                                <div class="conf cancle-confirm">Cancel</div>
                                                <button class="conf delete-confirm">Confirm</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
            </div>
        </div>


        <!-- listings show -->
        <hr>
        <div id="listing-box" data-aos="fade-up" data-aos-duration="1200" data-aos-offset="100">
            <div class="listing-count">
                <h3 class="index-res">@<%= currUser.username %> Created&nbsp;<b class="text-success fs-4">
                            <%= allListing.length %>
                        </b>&nbsp;Listings</h3>
                <form method="post" action="/profile/all-listings-delete/<%= currUser._id %>?_method=DELETE"
                    class="needs-validation">
                    <a href="/listings/new" class="deleteAll btn create-list">Create Li..</a>
                    <button type="reset" class="deleteAll btn delete-list" id="delete-confirm">Delete All</button>
                    <div class="fnx-fixed-dis">
                        <div class="delete-fnx" style="display: none;">
                            <p>Are you sure you want to delete the entire listings?</p>
                            <div class="conf cancle-confirm">Cancel</div>
                            <button class="conf delete-confirm">Confirm</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="row row-cols-xxl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-1 profile-box">
                <% for (const listing of allListing) { %>
                    <div class="listing-link">
                        <div class="card col listing-card index-res">
                            <div class="index-res-img">
                                <div class="card-img">
                                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" />
                                </div>
                                <div class="card-body mt-1 ms-2">
                                    <p class="card-text" style="display: block;">
                                        <b>
                                            <%= listing.title %>
                                        </b> <br>
                                        <span>&nbsp;<%= listing.location %>, <%= listing.country %></span>
                                    </p>
                                </div>
                                <div class="lists-btn mt-1">
                                    <button class="list-btn list-show"><a
                                            href="/listings/<%= listing._id %>">Show</a></button>
                                    <form method="post" action="/profile/listing/<%= listing._id %>?_method=DELETE"
                                        class="needs-validation">
                                        <button type="reset" class="list-btn list-delete"
                                            id="delete-confirm">Delete</button>
                                        <div class="fnx-fixed-dis">
                                            <div class="delete-fnx" style="display: none;">
                                                <p>I want to delete this listing.</p>
                                                <p>"<%= listing.title %>"</p>
                                                <div class="conf cancle-confirm">Cancel</div>
                                                <button class="conf delete-confirm">Confirm</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
            </div>
        </div>

        <!-- bookings show -->
        <div id="booking-box" style="display: none;" data-aos="fade-up" data-aos-duration="1200" data-aos-offset="100">
            <hr>
            <div class="listing-count">
                <h3 class="index-res">@<%= currUser.username %> Booked&nbsp;<b class="text-danger fs-4">
                            <%= allBooking.length %>
                        </b>&nbsp;Listings</h3>
            </div>
            <div class="row row-cols-xxl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-1 profile-box">
                <% for (const booking of allBooking) { %>
                    <% if (booking.listing) { %>
                    <div class="listing-link">
                        <div class="card col listing-card index-res shadow-sm" style="border-radius: 12px; overflow: hidden; transition: all 0.3s ease;">
                            <div class="index-res-img" style="height: 100%;">
                                <div class="card-img" style="height: 180px; position: relative;">
                                    <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 100%; object-fit: cover;" />
                                    <span class="badge bg-success position-absolute" style="top: 10px; right: 10px; padding: 6px 12px; border-radius: 20px;"><%= booking.status %></span>
                                </div>
                                <div class="card-body mt-2 ms-2" style="display: flex; flex-direction: column;">
                                    <h5 class="card-title text-truncate" style="font-weight: 700; font-size: 1.1rem; display: block !important;">
                                        <%= booking.listing.title %>
                                    </h5>
                                    <p class="card-text text-muted mb-2" style="font-size: 0.9rem; display: block !important;">
                                        <i class="fa-solid fa-location-dot text-danger me-1"></i><%= booking.listing.location %>, <%= booking.listing.country %>
                                    </p>
                                    <hr class="my-2">
                                    <div class="booking-dates text-dark mb-2" style="font-size: 0.85rem; line-height: 1.4;">
                                        <div><strong>Check-in:</strong> <%= new Date(booking.checkIn).toLocaleDateString("en-IN", {day: 'numeric', month: 'short', year: 'numeric'}) %></div>
                                        <div><strong>Check-out:</strong> <%= new Date(booking.checkOut).toLocaleDateString("en-IN", {day: 'numeric', month: 'short', year: 'numeric'}) %></div>
                                        <div><strong>Guests:</strong> <%= booking.guests %> guest<%= booking.guests > 1 ? 's' : '' %></div>
                                        <div class="mt-1 text-danger font-weight-bold" style="font-size: 1rem;"><strong>Paid:</strong> &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></div>
                                    </div>
                                </div>
                                <div class="lists-btn mt-1 d-flex justify-content-between p-2">
                                    <button class="list-btn list-show" style="width: 45%;"><a href="/listings/<%= booking.listing._id %>">Show</a></button>
                                    <form method="post" action="/profile/booking/<%= booking._id %>?_method=DELETE" class="needs-validation" style="width: 45%;">
                                        <button type="reset" class="list-btn list-delete w-100" id="delete-confirm" style="height: 2rem; border-radius: 20px;">Cancel</button>
                                        <div class="fnx-fixed-dis">
                                            <div class="delete-fnx" style="display: none;">
                                                <p>Cancel booking for</p>
                                                <p>"<%= booking.listing.title %>"?</p>
                                                <div class="conf cancle-confirm">Back</div>
                                                <button class="conf delete-confirm">Confirm</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="listing-link">
                        <div class="card col listing-card index-res p-3 text-center bg-light">
                            <p class="text-muted">Listing no longer exists.</p>
                            <form method="post" action="/profile/booking/<%= booking._id %>?_method=DELETE" class="needs-validation mt-2">
                                <button type="reset" class="btn btn-sm btn-outline-secondary" id="delete-confirm">Remove Record</button>
                                <div class="fnx-fixed-dis">
                                    <div class="delete-fnx" style="display: none;">
                                        <p>Remove this booking record?</p>
                                        <div class="conf cancle-confirm">Back</div>
                                        <button class="conf delete-confirm">Confirm</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <% } %>
                <% } %>
            </div>
        </div>
        <hr>


        <!-- reviews show -->
        <div id="review-box-end" data-aos="fade-up" data-aos-duration="1200" data-aos-offset="100">
            <div class="listing-count">
                <h3 class="index-res">@<%= currUser.username %> Created&nbsp;<b class="text-success fs-4">
                            <%= allReview.length %>
                        </b>&nbsp;Reviews</h3>
                <form method="post" action="/profile/all-reviews-delete/<%= currUser._id %>?_method=DELETE"
                    class="needs-validation">
                    <button type="reset" class="deleteAll btn delete-list" id="delete-confirm">Delete All</button>
                    <div class="fnx-fixed-dis">
                        <div class="delete-fnx" style="display: none;">
                            <p>Are you sure you want to delete the entire reviews?</p>
                            <div class="conf cancle-confirm">Cancel</div>
                            <button class="conf delete-confirm">Confirm</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="row row-cols-xxl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-1 profile-box">
                <% for (const review of allReview) { %>
                    <div class="listing-link">
                        <div class="card col listing-card index-res">
                            <div class="index-res-img">
                                <div class="card-body mt-1 ms-2" id="review-body">
                                    <span><b>Date :</b>
                                        <%= review.createAt.toString().split(" ").slice(1,4).join(" -") %>
                                    </span><br>
                                    <span><b>Time :</b>
                                        <%= review.createAt.toString().split(" ")[4] %></span><br>
                                    <span><b>Comment :</b> <%= review.comment %></span><br>
                                    <span class=" ratingBox"><b>Rating : &nbsp;</b>
                                            <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                    </span>
                                </div>
                                <div class="lists-btn mt-1">
                                    <button class="list-btn list-show"><a
                                            href="/listings/<%= review.listing %>">Show</a></button>
                                    <form method="post"
                                        action="/profile/review/<%= review.listing %>/<%= review._id %>?_method=DELETE"
                                        class="needs-validation">
                                        <button type="reset" class="list-btn list-delete"
                                            id="delete-confirm">Delete</button>
                                        <div class="fnx-fixed-dis">
                                            <div class="delete-fnx" style="display: none;">
                                                <p>I want to delete this review.</p>
                                                <p>"<%= review.comment %>"</p>
                                                <div class="conf cancle-confirm">Cancel</div>
                                                <button class="conf delete-confirm">Confirm</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
            </div>
        </div>
    </div>
    <script src="/js/delete-confirm.js"></script>
    <script src="/js/profile.js"></script>