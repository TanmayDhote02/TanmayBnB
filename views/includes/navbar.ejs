<link rel="stylesheet" href="/css/navbar.css"> <!-- link style file -->

<nav class="nav-box">
  <div id="nav-main">
    <div id="nav-main-bar">
      <div class="nav-icon" style="margin-left: 1.5rem;">
        <a href="/listings" style="display: flex; align-items: center; text-decoration: none;">
          <i class="fa-solid fa-house-chimney text-danger me-2" style="font-size: 24px;"></i>
          <span style="font-size: 24px; font-weight: 800; color: #FF385C; letter-spacing: -0.5px;">StayHest</span>
        </a>
      </div>
      <div class="nav-search nav-hover nav-search-search">
        <form class="d-flex needs-validation" role="search" action="/listings/search" method="get" id="searchBox">
          <input type="search" placeholder="Search" aria-label="Search" name="q" id="mySearchInput">
          <button type="submit" id="search"><i class="fa-solid fa-magnifying-glass"></i></i></button>
        </form>
      </div>
      <div class="nav-user nav-hover">
        <div>
          <img src="/Icon/navbar-icon.png" id="png-img-bar">
          <% if (typeof currUser !=='undefined' && currUser.image && currUser.image.url) { %>
            <img src="<%= currUser.image.url %>" alt="Profile" id="png-img-user">
            <% } else { %>
              <img src="/Icon/navbar-icon-user.png" alt="User" id="png-img-user">
              <% } %>
                <img src="/Icon/navbar-icon-cross.png" id="png-img-cross">
        </div>
      </div>
      <div class="user-fnx">
        <a href="/profile">Profile</a>
        <a href="/listings/new">StayHest your home</a>
        <% if (typeof currUser==='undefined' ) { %>
          <a href="/signup">SignUp</a>
          <a href="/login">LogIn</a>
          <% } %>
            <% if (typeof currUser !=='undefined' ) { %>
              <a href="/logout">LogOut</a>
              <% } %>
      </div>
    </div>
    <div id="nav-search-hide">
      <div class="nav-search nav-hover">
        <form class="d-flex needs-validation" role="search" action="/listings/search" method="get" id="searchBox">
          <input type="search" placeholder="Search" aria-label="Search" name="q" id="mySearchInput">
          <button type="submit" id="search"><i class="fa-solid fa-magnifying-glass"></i></i></button>
        </form>
      </div>
    </div>
  </div>
</nav>
<script src="/js/navbar.js"></script>